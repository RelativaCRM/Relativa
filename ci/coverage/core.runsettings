<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[Relativa.Core]*,[Relativa.Core.Application]*,[Relativa.Core.Domain]*,[Relativa.Core.Infrastructure]*,[Relativa.Persistence]*,[Relativa.Messaging]*</Include>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
