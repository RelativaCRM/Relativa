# ==============================================================================
#  Relativa — Environment Configuration Template
#
# ❌ НІКОЛИ не комітьте файл .env у репозиторій — його додано до .gitignore.
# ==============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Хост бази даних (у Docker Compose — ім'я сервісу)
DB_HOST=postgres

# Порт PostgreSQL всередині контейнера
DB_PORT=5432

# Назва бази даних, яку Migration створить/використовуватиме
DB_NAME=relativa

# Ім'я користувача PostgreSQL
DB_USER=relativa

# Пароль користувача PostgreSQL
DB_PASS=relativa

# ── pgAdmin ────────────────────────────────────────────────────────────────────
# Порт, на якому pgAdmin буде доступний на хост-машині
PGADMIN_PORT=5050

# Email для входу в інтерфейс pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@relativa.com

# Пароль для входу в інтерфейс pgAdmin
PGADMIN_DEFAULT_PASSWORD=admin123

# ── SMTP / Email ───────────────────────────────────────────────────────────────
# ⚠️  Залиште SMTP_HOST=mailhog для локальної розробки (MailHog перехоплює листи).
#   Для реального відправлення — вкажіть дані вашого SMTP-провайдера.

# Хост SMTP-сервера
SMTP_HOST=mailhog

# SMTP-порт (1025 — MailHog; 587 — TLS; 465 — SSL)
SMTP_PORT=1025

# Ім'я користувача SMTP (залиште порожнім для MailHog)
SMTP_USERNAME=

# Пароль SMTP (залиште порожнім для MailHog)
SMTP_PASSWORD=

# Адреса відправника листів
SMTP_FROM_ADDRESS=noreply@relativa.com

# Ім'я відправника (відображається в поштовому клієнті)
SMTP_FROM_NAME=Relativa

# Увімкнути SSL для SMTP? (true / false)
SMTP_USE_SSL=false

# ── Application ────────────────────────────────────────────────────────────────
# Базовий URL фронтенду — використовується бекендом для формування посилань у листах
APP_FRONTEND_BASE_URL=http://localhost:3000

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Порт, на якому клієнтський Vite dev-сервер буде доступний на хості
CLIENT_PORT=3000

# URL шлюзу (Gateway), до якого SPA надсилає всі API-запити
# Має збігатися з адресою, доступною з браузера
VITE_GATEWAY_URL=http://localhost:8080

# ── Gateway CORS ───────────────────────────────────────────────────────────────
# Перелік дозволених origin для браузерних запитів через Gateway.
# Додайте сюди адресу, з якої відкриваєте застосунок.

# Перший дозволений origin (Vite dev-сервер за замовчуванням)
CORS_ORIGIN_1=http://localhost:5173

# Другий дозволений origin (Docker-клієнт)
CORS_ORIGIN_2=http://localhost:3000

# ⚠️  Лише для локальної розробки: true вмикає wildcard CORS (без credentials).
# Ніколи не встановлюйте true у production.
CORS_ALLOW_ANY_ORIGIN_FOR_DEV=false

# ── JWT (Authentication & Gateway) ────────────────────────────────────────────
# ⚠️  Усі три змінні ПОВИННІ бути однаковими у сервісах auth та gateway.
#    Невідповідність спричинить помилку 401 на всіх захищених ендпоінтах.

# Секретний ключ для підпису JWT (HMAC-SHA256).
# Мінімум 32 символи. Згенеруйте унікальне значення для кожного оточення.
JWT_SECRET=super-secret-key-that-should-be-at-least-32-chars!

# Ідентифікатор видавця токена (claim "iss")
JWT_ISSUER=relativa-auth

# Ідентифікатор аудиторії токена (claim "aud")
JWT_AUDIENCE=relativa
