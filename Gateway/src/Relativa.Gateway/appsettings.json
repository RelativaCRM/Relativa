{
  "Urls": "http://*:8080",
  "Jwt": {
    "SecretKey": "super-secret-key-that-should-be-at-least-32-chars!",
    "Issuer": "relativa-auth",
    "Audience": "relativa"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-login": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/login" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-register": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/register" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-health": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/health" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Default"
      },
      "core-health": {
        "ClusterId": "core",
        "Match": { "Path": "/core/health" },
        "Transforms": [ { "PathRemovePrefix": "/core" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "core": {
        "ClusterId": "core",
        "Match": { "Path": "/core/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/core" } ],
        "AuthorizationPolicy": "Default"
      },
      "graph": {
        "ClusterId": "graph",
        "Match": { "Path": "/graph/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/graph" } ],
        "AuthorizationPolicy": "Default"
      },
      "ml": {
        "ClusterId": "ml",
        "Match": { "Path": "/ml/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/ml" } ],
        "AuthorizationPolicy": "Default"
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/audit/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/audit" } ],
        "AuthorizationPolicy": "Default"
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8081/" } }
      },
      "core": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8082/" } }
      },
      "graph": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8083/" } }
      },
      "ml": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8084/" } }
      },
      "audit": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8086/" } }
      }
    }
  }
}
