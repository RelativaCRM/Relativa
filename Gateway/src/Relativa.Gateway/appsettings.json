{
  "Urls": "http://*:8080",
  "Jwt": {
    "SecretKey": "super-secret-key-that-should-be-at-least-32-chars!",
    "Issuer": "relativa-auth",
    "Audience": "relativa"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173", "http://localhost:3000" ],
    "AllowAnyOriginForDev": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-login": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/login" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-exists": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/exists" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-register": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/register" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-oauth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/oauth/{provider}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-forgot-password": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/forgot-password" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-verify-email": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/verify-email" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-resend-verification": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/resend-verification" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-verification-channels": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/verification-channels" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-support": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/support/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-reset-password": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/reset-password" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-validate-reset-token": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/api/v1/auth/reset-password/validate" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth-health": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/health" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/auth/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/auth" } ]
      },
      "core-health": {
        "ClusterId": "core",
        "Match": { "Path": "/core/health" },
        "Transforms": [ { "PathRemovePrefix": "/core" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "core-entity-types": {
        "ClusterId": "core",
        "Match": { "Path": "/core/api/v1/entity-types" },
        "Transforms": [ { "PathRemovePrefix": "/core" } ],
        "AuthorizationPolicy": "Anonymous"
      },
      "core": {
        "ClusterId": "core",
        "Match": { "Path": "/core/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/core" } ]
      },
      "graph": {
        "ClusterId": "graph",
        "Match": { "Path": "/graph/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/graph" } ]
      },
      "ml": {
        "ClusterId": "ml",
        "Match": { "Path": "/ml/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/ml" } ]
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/audit/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/audit" } ]
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8081/" } }
      },
      "core": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8082/" } }
      },
      "graph": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8083/" } }
      },
      "ml": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8084/" } }
      },
      "audit": {
        "Destinations": { "d1": { "Address": "http://127.0.0.1:8086/" } }
      }
    }
  }
}
