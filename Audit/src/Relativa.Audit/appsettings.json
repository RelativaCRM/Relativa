{
  "Urls": "http://*:8086",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=relativa;Username=relativa;Password=relativa"
  },
  "Jwt": {
    "SecretKey": "super-secret-key-that-should-be-at-least-32-chars!",
    "Issuer": "relativa-auth",
    "Audience": "relativa"
  },
  "AuditLogRead": {
    "DefaultDateRangeDays": 30
  },
  "RabbitMqAudit": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "Exchange": "audit.events",
    "Queue": "audit.events.audit",
    "RoutingKey": "audit.#"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
